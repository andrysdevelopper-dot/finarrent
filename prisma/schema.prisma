generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./prisma/dev.db"
}

model DemandeFinancement {
  id            String   @id @default(cuid())
  reference     String   @unique
  requestType   String
  companyName   String
  siren         String
  sector        String
  amount        String
  equipmentType String?
  firstName     String
  lastName      String
  email         String
  phone         String
  message       String?
  status        String   @default("en_attente")
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  adminNotes    String?
}
